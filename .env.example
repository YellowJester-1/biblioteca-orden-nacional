# -----------------------------------------------------------------------------
# Plantilla de variables de entorno — Biblioteca Orden Nacional
# Copiar este archivo a `.env` y reemplazar los valores antes de levantar el stack.
#
#   cp .env.example .env
#
# El archivo `.env` está ignorado por git, así que las credenciales reales
# nunca entran al repositorio.
# -----------------------------------------------------------------------------

# --- Base de datos ---
# Generá passwords fuertes:  node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
MYSQL_ROOT_PASSWORD=cambiar-por-password-fuerte
DB_USER=orden
DB_PASSWORD=cambiar-por-password-fuerte
DB_NAME=biblioteca

# --- App ---
NODE_ENV=development
PORT=3000

# --- Admin del panel /admin ---
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-por-password-fuerte
# ADMIN_SECRET firma la cookie de sesión. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=cambiar-por-secreto-largo-y-aleatorio
